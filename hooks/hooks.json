{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-bash.sh",
            "description": "Allow only safe Bash commands (python, chmod secrets, curl testrail, pip/uv install)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
